# Phantom Engine — Environment Variables
# Copy this file to .env and fill in your values before running.
# Never commit .env to version control (it is in .gitignore).

# =============================================================================
# Server
# =============================================================================

# Port for the MCP / HTTP server
PHANTOM_PORT=8080

# Port for the Prometheus metrics endpoint
PHANTOM_METRICS_PORT=9091

# Maximum number of concurrent browser sessions
PHANTOM_MAX_SESSIONS=1000

# =============================================================================
# Authentication
# =============================================================================

# Comma-separated list of API keys.
# Agents must send X-API-Key: <key> header on every request.
# Leave empty to disable auth (development only).
PHANTOM_API_KEYS=phantom-secret-change-me

# =============================================================================
# Logging
# =============================================================================

# Log level: error | warn | info | debug | trace
RUST_LOG=info

# Emit logs as JSON (recommended for production / log aggregators)
PHANTOM_JSON_LOGS=false

# =============================================================================
# Grafana (docker-compose only)
# =============================================================================

GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=phantom
